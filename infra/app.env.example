# wn-panel runtime env — template (kopiuj do /opt/wn-app/.env na VM i wypełnij)
# Secrets nigdy NIE commitujemy do repo.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database — URL z hasłem z ~/.secrets/wolny-namiot/db-creds.env
DATABASE_URL=postgres://wn:CHANGE_ME@10.10.0.43:5432/wn_panel

# Keycloak — realm wolny_namiot na auth.vavolabs.pl
KEYCLOAK_ISSUER=https://auth.vavolabs.pl/realms/wolny_namiot
KEYCLOAK_CLIENT_ID=wn-panel-app
KEYCLOAK_CLIENT_SECRET=CHANGE_ME  # z KC admin: Clients > wn-panel-app > Credentials

# App sekrety (openssl rand -base64 32)
API_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME

# Resend (https://resend.com/api-keys) — domena wolnynamiot.pl verified
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM=biuro@wolnynamiot.pl

# Public URL widoczny w emailach/PDFach
PUBLIC_BASE_URL=https://panel.wolnynamiot.pl

# Adapter-node proxy trust — CF Tunnel wysyła X-Forwarded-*
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host

# Cloudflare Tunnel (same env_file czyta cloudflared container)
TUNNEL_TOKEN=CHANGE_ME  # z CF Dashboard: Zero Trust > Networks > Tunnels > Configure

# Gotenberg — HTML→PDF service w compose network bridge
GOTENBERG_URL=http://gotenberg:3000

# Internal URL dla Gotenberg chromium render → wn-app (static IP, Chrome skip HTTPS-First)
INTERNAL_APP_URL=http://172.25.0.10:3000
